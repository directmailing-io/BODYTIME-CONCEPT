# ============================================================
# BODYTIME concept – Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ============================================================

# ---- Supabase (Public – safe for client) ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ---- Supabase (Server-only – NEVER expose to client) ----
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Email (Nodemailer – server-only) ----
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@bodytime-concept.de
SMTP_PASS=your-smtp-password
SMTP_FROM_NAME=BODYTIME concept
SMTP_FROM_EMAIL=noreply@bodytime-concept.de

# ---- Cron / Background Jobs ----
# Secret used to verify cron job requests
CRON_SECRET=your-cron-secret-here
